{
  "name": "euron-agent",
  "displayName": "Euron Coding Agent",
  "description": "Lightweight agentic coding assistant (Cline/OpenCode-style). Plan, edit, and run code with approvals. Works with Euron/Euri, OpenAI, OpenRouter, Anthropic, Ollama, or any OpenAI-compatible/self-hosted model.",
  "version": "1.0.6",
  "publisher": "Euron",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "copilot",
    "cline",
    "coding assistant",
    "llm",
    "ollama",
    "openai",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/euron-tech/Euron-coding-agent.git"
  },
  "bugs": {
    "url": "https://github.com/euron-tech/Euron-coding-agent/issues"
  },
  "homepage": "https://github.com/euron-tech/Euron-coding-agent#readme",
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "euronAgent",
          "title": "Euron Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "euronAgent": [
        {
          "type": "webview",
          "id": "euronAgent.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "euronAgent.openChat",
        "title": "Open Chat",
        "category": "Euron Agent"
      },
      {
        "command": "euronAgent.setApiKey",
        "title": "Set API Key / Provider",
        "category": "Euron Agent",
        "icon": "$(key)"
      },
      {
        "command": "euronAgent.selectProvider",
        "title": "Select Provider",
        "category": "Euron Agent",
        "icon": "$(server)"
      },
      {
        "command": "euronAgent.restartBackend",
        "title": "Restart Backend",
        "category": "Euron Agent",
        "icon": "$(debug-restart)"
      },
      {
        "command": "euronAgent.stop",
        "title": "Stop Current Task",
        "category": "Euron Agent",
        "icon": "$(stop-circle)"
      },
      {
        "command": "euronAgent.undo",
        "title": "Undo Last Task's Changes",
        "category": "Euron Agent",
        "icon": "$(discard)"
      },
      {
        "command": "euronAgent.toggleAutoApprove",
        "title": "Toggle Auto-Approve",
        "category": "Euron Agent",
        "icon": "$(check-all)"
      },
      {
        "command": "euronAgent.togglePlanMode",
        "title": "Toggle Plan Mode",
        "category": "Euron Agent",
        "icon": "$(checklist)"
      },
      {
        "command": "euronAgent.toggleDangerous",
        "title": "Toggle Dangerous Mode (no approvals)",
        "category": "Euron Agent",
        "icon": "$(flame)"
      },
      {
        "command": "euronAgent.selectWorkspace",
        "title": "Select Workspace Folder",
        "category": "Euron Agent",
        "icon": "$(folder)"
      },
      {
        "command": "euronAgent.setModel",
        "title": "Set Model",
        "category": "Euron Agent"
      },
      {
        "command": "euronAgent.attachImage",
        "title": "Attach Image",
        "category": "Euron Agent",
        "icon": "$(device-camera)"
      },
      {
        "command": "euronAgent.initMemory",
        "title": "Create Project Memory (AGENTS.md)",
        "category": "Euron Agent"
      },
      {
        "command": "euronAgent.fixDiagnostics",
        "title": "Fix Diagnostics",
        "category": "Euron Agent",
        "icon": "$(debug-alt)"
      },
      {
        "command": "euronAgent.review",
        "title": "Review Changes",
        "category": "Euron Agent",
        "icon": "$(search-fuzzy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "euronAgent.selectProvider",
          "when": "view == euronAgent.chat",
          "group": "navigation@1"
        },
        {
          "command": "euronAgent.setApiKey",
          "when": "view == euronAgent.chat",
          "group": "navigation@2"
        },
        {
          "command": "euronAgent.togglePlanMode",
          "when": "view == euronAgent.chat",
          "group": "navigation@3"
        },
        {
          "command": "euronAgent.toggleAutoApprove",
          "when": "view == euronAgent.chat",
          "group": "navigation@4"
        },
        {
          "command": "euronAgent.toggleDangerous",
          "when": "view == euronAgent.chat",
          "group": "navigation@5"
        },
        {
          "command": "euronAgent.restartBackend",
          "when": "view == euronAgent.chat",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": {
      "title": "Euron Agent",
      "properties": {
        "euronAgent.model": {
          "type": "string",
          "default": "",
          "description": "Override the model id for the active provider. Empty = provider default."
        },
        "euronAgent.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python 3.9+ executable used for the managed backend. Empty = auto-detect (python3 / python / py)."
        },
        "euronAgent.backendVersion": {
          "type": "string",
          "default": "",
          "description": "Pin the euron-agent backend version installed from PyPI. Empty = latest."
        },
        "euronAgent.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Advanced: connect to a backend you run yourself (e.g. ws://127.0.0.1:8000/ws). Empty = the extension auto-installs and manages the backend for you."
        },
        "euronAgent.token": {
          "type": "string",
          "default": "",
          "description": "Bearer token for a remote/self-hosted backend (euronAgent.serverUrl). Not needed for the auto-managed local backend."
        },
        "euronAgent.persistHistory": {
          "type": "boolean",
          "default": true,
          "description": "Remember the conversation per workspace across reloads."
        },
        "euronAgent.effort": {
          "type": "string",
          "enum": ["", "low", "medium", "high"],
          "default": "",
          "description": "Reasoning effort for reasoning/thinking-capable models (empty = default)."
        },
        "euronAgent.autoDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "After a task, offer to fix new error diagnostics in the files the agent changed."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "esbuild": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile": "node esbuild.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.20.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.4.0"
  }
}
